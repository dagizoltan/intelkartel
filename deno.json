{
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.11.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.11",
    "hono": "npm:hono@^4.11.8"
  },
      "compilerOptions": {
        "jsx": "precompile",
        "jsxImportSource": "hono/jsx"
    },
    "tasks": {
        "collect-media": "deno run --allow-read --allow-write --allow-net media-collector.js",
        "convert_img": "deno run -A convert_img.js",
        "compress_webp": "deno run -A compress_webp.js"
    }
}
